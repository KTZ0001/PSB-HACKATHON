# Aegis configuration — copy to .env and adjust as needed.
# All values have sane defaults in src/config; .env only overrides them.

# --- API ---
AEGIS_API_HOST=0.0.0.0
AEGIS_API_PORT=8000

# --- Model artifacts ---
# Directory where trained models (isolation forest, xgboost, graph) are saved.
AEGIS_MODEL_DIR=models_store

# --- Kaggle ---
# Auth is handled by the Kaggle CLI's own login state (kaggle auth login) or
# the KAGGLE_API_TOKEN env var. Aegis does NOT read a kaggle.json file.
# Uncomment and set only if you are using token-based auth in this shell:
# KAGGLE_API_TOKEN=
